# xAI API
XAI_API_KEY=
XAI_API_URL=wss://api.x.ai/v1/realtime
XAI_MODEL=grok-voice-think-fast-1.0

# Server
PORT=8080
HOSTNAME=

# Supabase
SUPABASE_URL=
