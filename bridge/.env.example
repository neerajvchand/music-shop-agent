# Bridge configuration
FAREWELL_SAFETY_TIMEOUT_MS=8000
SILENCE_TIMEOUT_MS=30000
CALL_TIMEOUT_MS=300000
GOODBYE_DRAIN_MS=3000

# Logging
LOG_LEVEL=info
