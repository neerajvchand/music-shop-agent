# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (Vercel or Railway)
NEXT_PUBLIC_APP_URL=https://your-dashboard.vercel.app

# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Agent ↔ Vercel HMAC auth (shared secret between Railway and Vercel)
AGENT_API_SECRET=generate-a-random-32-char-string

# Cron secret (for Vercel cron jobs)
CRON_SECRET=generate-another-random-string
